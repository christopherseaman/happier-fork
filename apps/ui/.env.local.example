# Local dev-only Expo env overrides (do not commit secrets)
#
# Usage:
#   cp .env.local.example .env.local
#   (then restart Expo/Metro)
#
# IMPORTANT:
# - Only `EXPO_PUBLIC_*` variables are embedded into the app JS bundle at build/bundle time.
# - Treat all `EXPO_PUBLIC_*` values as public (never put secrets here).
#
# Build-time feature gating (comma-separated FeatureId list).
# Example: disable voice and friends UI no matter what the server advertises.
EXPO_PUBLIC_HAPPIER_BUILD_FEATURES_DENY=voice,social.friends
#
# Optional allowlist (usually unnecessary; deny is the common case).
# EXPO_PUBLIC_HAPPIER_BUILD_FEATURES_ALLOW=

