{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Happier",
  "version": "0.1.0",
  "identifier": "dev.happier.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "yarn start",
    "beforeBuildCommand": "yarn expo export --platform web --output-dir dist"
  },
  "app": {
    "windows": [
      {
        "title": "Happier",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCRTk2MjE4RjNCMEYxRUYKUldUdjhiRHpHR0xwcTFIUjMvb1FBbW5HOUFYSkd5aGlHa204MWZuRk50ekF5WVZQdU1mVkRWWnkK",
      "endpoints": [
        "https://github.com/happier-dev/happier/releases/download/ui-desktop-stable/latest.json"
      ]
    }
  }
}
