{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.14.0",
      "android": {
        "gradleCommand": ":app:bundleRelease -x lintVitalRelease -x lintVitalAnalyzeRelease"
      }
    },
    "development": {
      "extends": "base",
      "environment": "development",
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development"
      }
    },
    "development-store": {
      "extends": "base",
      "environment": "development",
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "store",
      "channel": "development",
      "env": {
        "APP_ENV": "development"
      }
    },
    "preview": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview"
      }
    },
    "preview-apk": {
      "extends": "base",
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_ENV": "production"
      }
    },
    "production-apk": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "steve@bulkovo.com",
        "ascAppId": "126165711",
        "appleTeamId": "L86V3EF623"
      }
    }
  }
}
